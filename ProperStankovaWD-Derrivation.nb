         RowBox[{"\"\<x (m)\>\"", ",", "\"\<NEC\>\""}], "}"}]}], ",", 
       RowBox[{"Filling", "->", "Axis"}], ",", 
       RowBox[{"FillingStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Purple", ",", 
          RowBox[{"Opacity", "[", "0.3", "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "NECPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 6: 2D Energy Density Map ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"T00Map", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"T00Total", "[", 
        RowBox[{"x", ",", "0", ",", "z", ",", "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T00MapPlot", "=", 
     RowBox[{"ArrayPlot", "[", 
      RowBox[{"T00Map", ",", 
       RowBox[{"ColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<T00(x,z) Energy Density Map\>\""}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<z\>\""}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "T00MapPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 7: 3D Energy Density ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"coords3D", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y", ",", "z", ",", 
           RowBox[{"T00Total", "[", 
            RowBox[{"x", ",", "y", ",", "z", ",", "0"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"z", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}]}], "]"}],
        ",", "2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T00Plot3D", "=", 
     RowBox[{"ListDensityPlot3D", "[", 
      RowBox[{"coords3D", ",", 
       RowBox[{"ColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<3D Energy Density\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}]}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "T00Plot3D", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== Section 8: Bubble Motion ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"timePositions", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{"vBubble", "*", "t"}], ",", 
         RowBox[{"-", 
          RowBox[{"Min", "[", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"T00Total", "[", 
              RowBox[{"x", ",", "0", ",", "0", ",", "t"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "grid"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "1.5", ",", "0.1"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"motionPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"timePositions", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
          RowBox[{"timePositions", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "3"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"\"\<Bubble Position vs Time - v = \>\"", "<>", 
         RowBox[{"ToString", "[", "vBubble", "]"}], "<>", "\"\< c\>\""}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x_center (m)\>\"", ",", "\"\<Peak |T00|\>\""}], 
         "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "motionPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== Section 9: Snapshots ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"snapshots", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"T00Total", "[", 
              RowBox[{"x", ",", "0", ",", "0", ",", "t"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "grid"}], "}"}]}], "]"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"PlotStyle", "->", "Thick"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"\"\<t = \>\"", "<>", 
           RowBox[{"ToString", "[", "t", "]"}], 
           "<>", "\"\< s, x_center = \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"vBubble", "*", "t"}], "]"}], "<>", "\"\< m\>\""}]}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<x (m)\>\"", ",", "\"\<T00\>\""}], "}"}]}], ",", 
         RowBox[{"Filling", "->", "Axis"}], ",", 
         RowBox[{"FillingStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Red", ",", 
            RowBox[{"Opacity", "[", "0.2", "]"}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "1.2", ",", "0.3"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "snapshots", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 10: Metric Components ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"gttLine", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"gtt", "[", 
          RowBox[{"x", ",", "0", ",", "0", ",", "0"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gtxLine", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"gtx", "[", 
          RowBox[{"x", ",", "0", ",", "0", ",", "0"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gttPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"gttLine", ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Orange"}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", 
        "->", "\"\<g_tt(x) - The time-time metric component\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x (m)\>\"", ",", "\"\<g_tt\>\""}], "}"}]}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "gttPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gtxPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"gtxLine", ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Cyan"}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<g_tx(x) - The shift vector component\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x (m)\>\"", ",", "\"\<g_tx\>\""}], "}"}]}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "gtxPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== Section 11: FTL CHECK ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Bubble velocity: \>\"", ",", "vBubble", ",", "\"\< c\>\""}],
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<FTL capable: \>\"", ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"vBubble", ">", "1"}], 
        ",", "\"\<YES! The bubble moves faster than light!\>\"", 
        ",", "\"\<No (v < c)\>\""}], "]"}]}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"vBubble", ">", "1"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", "[", "\"\<*** STANKOVA WARP BUBBLE: FTL ACHIEVED! ***\>\"", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<The bubble moves at \>\"", ",", "vBubble", 
         ",", "\"\< times the speed of light.\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<The warp shape function f(x) comes from the Stankova field \
itself:\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<  f(x) = 1 - Phi(x)/Phi(0)\>\"", "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Energy sources:\>\"", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<  - Brans-Dicke: Positive energy from scalar gradients\>\"",
         "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<  - Born-Infeld: Negative energy from nonlinear EM\>\"", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<  - Shell: Anisotropic stresses\>\"", "]"}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<Requires negative energy density (exotic matter).\>\"", 
        "]"}], ";"}]}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== END OF SIMULATION ===\>\"", "]"}], 
    ";"}]}]}]], "Input",
