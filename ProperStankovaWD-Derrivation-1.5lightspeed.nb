       "PlotLabel", 
        "->", "\"\<Optimal Energy Density T00(x) - Negative energy\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x (m)\>\"", ",", "\"\<T00\>\""}], "}"}]}], ",", 
       RowBox[{"Filling", "->", "Axis"}], ",", 
       RowBox[{"FillingStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Red", ",", 
          RowBox[{"Opacity", "[", "0.3", "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "T00Plot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 4: 2D Energy Density Map (Optimal) ===\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T00Map", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"T00Opt", "[", 
        RowBox[{"x", ",", "0", ",", "z", ",", "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T00MapPlot", "=", 
     RowBox[{"ArrayPlot", "[", 
      RowBox[{"T00Map", ",", 
       RowBox[{"ColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<Optimal T00(x,z) Energy Density Map\>\""}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<z\>\""}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "T00MapPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 5: 3D Energy Density (Optimal) ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coords3D", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y", ",", "z", ",", 
           RowBox[{"T00Opt", "[", 
            RowBox[{"x", ",", "y", ",", "z", ",", "0"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"z", ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"-", "1"}], ";;", "5"}], "]"}], "]"}]}], "}"}]}], "]"}],
        ",", "2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T00Plot3D", "=", 
     RowBox[{"ListDensityPlot3D", "[", 
      RowBox[{"coords3D", ",", 
       RowBox[{"ColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Optimal 3D Energy Density\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}]}],
       "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "T00Plot3D", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 6: Bubble Motion (Optimal) ===\>\"", "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"timePositions", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{"vopt", "*", "t"}], ",", 
         RowBox[{"-", 
          RowBox[{"Min", "[", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"T00Opt", "[", 
              RowBox[{"x", ",", "0", ",", "0", ",", "t"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "grid"}], "}"}]}], "]"}], "]"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "1.5", ",", "0.1"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"motionPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"timePositions", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
          RowBox[{"timePositions", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "3"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"\"\<Optimal Bubble Position vs Time - v = \>\"", "<>", 
         RowBox[{"ToString", "[", "vopt", "]"}], "<>", "\"\< c\>\""}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x_center (m)\>\"", ",", "\"\<Peak |T00|\>\""}], 
         "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "motionPlot", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 7: Snapshots (Optimal) ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"snapshots", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"T00Opt", "[", 
              RowBox[{"x", ",", "0", ",", "0", ",", "t"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "grid"}], "}"}]}], "]"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"PlotStyle", "->", "Thick"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"\"\<t = \>\"", "<>", 
           RowBox[{"ToString", "[", "t", "]"}], 
           "<>", "\"\< s, x_center = \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"vopt", "*", "t"}], "]"}], "<>", "\"\< m\>\""}]}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<x (m)\>\"", ",", "\"\<T00\>\""}], "}"}]}], ",", 
         RowBox[{"Filling", "->", "Axis"}], ",", 
         RowBox[{"FillingStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Red", ",", 
            RowBox[{"Opacity", "[", "0.2", "]"}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "1.2", ",", "0.3"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "snapshots", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Section 8: Comparison with Paper's Parameters \
===\>\"", "]"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Calculate", " ", "energy", " ", "for", " ", 
     RowBox[{"paper", "'"}], "s", " ", "parameters"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"EnergyPaper", "=", 
     RowBox[{"CalculateEnergy", "[", 
      RowBox[{"2.0", ",", "0.2", ",", "0.01", ",", "2.0"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"EnergyOptimal", "=", "bestEnergy"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Paper's parameters (R0=2.0, w=0.2, A=0.01, v=2.0): \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"EnergyPaper", ",", "4"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Optimal parameters: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{"EnergyOptimal", ",", "4"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Improvement: \>\"", ",", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"EnergyPaper", "-", "EnergyOptimal"}], ")"}], "/", 
          RowBox[{"Abs", "[", "EnergyPaper", "]"}]}], "*", "100"}], ",", 
        "4"}], "]"}], ",", "\"\<% less exotic matter\>\""}], "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== END OF OPTIMIZATION ===\>\"", "]"}], 
    ";"}]}]}]], "Input",
