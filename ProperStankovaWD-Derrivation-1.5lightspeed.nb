                  ",", "\"\< \[RightArrow] Energy: \>\"", ",", 
                  RowBox[{"N", "[", 
                   RowBox[{"energy", ",", "4"}], "]"}]}], "]"}], ";"}]}], 
              "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"v", ",", "vRange"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"A", ",", "Arange"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"w", ",", "wRange"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
