    RowBox[{"totalCombinations", "=", 
     RowBox[{
      RowBox[{"Length", "[", "R0range", "]"}], "*", 
      RowBox[{"Length", "[", "wRange", "]"}], "*", 
      RowBox[{"Length", "[", "Arange", "]"}], "*", 
      RowBox[{"Length", "[", "vRange", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"counter", "=", "0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Grid", " ", "search"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"counter", "++"}], ";", "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Mod", "[", 
                 RowBox[{"counter", ",", "10"}], "]"}], "==", "0"}], ",", 
               RowBox[{"Print", "[", 
                
                RowBox[{"\"\<Progress: \>\"", ",", "counter", ",", "\"\</\>\"",
                  ",", "totalCombinations", 
