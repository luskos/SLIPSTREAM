        "\[IndentingNewLine]", 
        RowBox[{"phi", "=", 
         RowBox[{"PhiOpt", "[", 
          RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"f", "=", 
         RowBox[{"fOpt", "[", 
          RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"vopt", "^", "2"}], "/", 
            RowBox[{"(", 
             RowBox[{"8", "*", "Pi"}], ")"}]}], ")"}]}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{"2", "*", "phi"}], "]"}], "*", 
         RowBox[{"(", 
          RowBox[{
