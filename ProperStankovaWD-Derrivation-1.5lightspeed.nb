             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"energy", "<", "bestEnergy"}], "&&", 
                RowBox[{"energy", ">", 
                 RowBox[{"-", 
                  RowBox[{"10", "^", "10"}]}]}]}], ",", 
               RowBox[{
                RowBox[{"bestEnergy", "=", "energy"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"bestParams", "=", 
                 RowBox[{"{", 
                  RowBox[{"R0", ",", "w", ",", "A", ",", "v"}], "}"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"Print", "[", 
                 
                 RowBox[{"\"\<New best! R0=\>\"", ",", "R0", 
