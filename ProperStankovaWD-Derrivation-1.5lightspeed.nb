        RowBox[{"PhiOpt", "[", 
         RowBox[{
          RowBox[{"x", "-", "h"}], ",", "y", ",", "z", ",", "t"}], "]"}]}], 
       ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "h"}], ")"}]}]}], ";"}], "\n", 
