     RowBox[{"bestParams", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"vopt", "=", 
     RowBox[{"bestParams", "[", 
      RowBox[{"[", "4", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "the", " ", "optimal", " ", "field"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PhiOpt", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "r", "}"}], ",", 
       RowBox[{
        RowBox[{"r", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", "-", 
              RowBox[{"vopt", "*", "t"}]}], ")"}], "^", "2"}], "+", 
           RowBox[{"y", "^", "2"}], "+", 
           RowBox[{"z", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"r", "<", "0.001"}], ",", "0", ",", 
          RowBox[{
           RowBox[{"-", "Aopt"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"R0opt", "/", "r"}]}], ")"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"r", "-", "R0opt"}], ")"}], "^", "2"}]}], "/", 
             RowBox[{"wopt", "^", "2"}]}], "]"}]}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PhiMaxOpt", "=", 
     RowBox[{
      RowBox[{"-", "Aopt"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"R0opt", "/", "0.001"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"0.001", "-", "R0opt"}], ")"}], "^", "2"}]}], "/", 
        RowBox[{"wopt", "^", "2"}]}], "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fOpt", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "phi", "}"}], ",", 
       RowBox[{
        RowBox[{"phi", "=", 
         RowBox[{"PhiOpt", "[", 
          RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "PhiMaxOpt", "]"}], "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "6"}]}]}], ",", "1", ",", 
          RowBox[{"1", "-", 
           RowBox[{"phi", "/", "PhiMaxOpt"}]}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Derivatives", " ", "for", " ", "optimal", " ", "parameters"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"h", "=", "0.001"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PhiXopt", "[", 
