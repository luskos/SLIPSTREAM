          RowBox[{"NumericQ", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "Complex"}], "]"}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "Indeterminate"}], "]"}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "DirectedInfinity"}], "]"}]}], ")"}], "&"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
