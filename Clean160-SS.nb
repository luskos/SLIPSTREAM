    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== SECTION 51: Stress-Energy Eigenvalues ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"TEigen", "[", 
      RowBox[{"x_", ",", "z_"}], "]"}], ":=", 
     RowBox[{"Eigenvalues", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"TijTotal", "[", 
         RowBox[{"i", ",", "j", ",", "x", ",", "0", ",", "z", ",", "0"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lambda1", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"TEigen", "[", 
         RowBox[{"x", ",", "0"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lambda2", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"TEigen", "[", 
         RowBox[{"x", ",", "0"}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lambda3", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"TEigen", "[", 
         RowBox[{"x", ",", "0"}], "]"}], "[", 
        RowBox[{"[", "3", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eigPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"grid", ",", "lambda1"}], "}"}], "]"}], ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"grid", ",", "lambda2"}], "}"}], "]"}], ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"grid", ",", "lambda3"}], "}"}], "]"}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Red", ",", "Blue", ",", "Green"}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<Eigenvalues of T_ij along x-axis\>\""}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "eigPlot", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"SECTION", " ", "52"}], "-", 
     RowBox[{"COMPREHENSIVE", " ", "KRETSCHMANN"}]}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== SECTION 52: Full Kretschmann Maps ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Kretschmann", "[", 
      RowBox[{"x_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"LapPhi", "[", 
         RowBox[{"x", ",", "0", ",", "z", ",", "0"}], "]"}], ")"}], "^", 
       "2"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"NormGradPhi", "[", 
         RowBox[{"x", ",", "0", ",", "z", ",", "0"}], "]"}], ")"}], "^", 
       "2"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"K2D2", "=", 
     RowBox[{"DensityPlot", "[", 
      RowBox[{
       RowBox[{"Kretschmann", "[", 
        RowBox[{"x", ",", "z"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "L"}], ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", 
         RowBox[{"-", "L"}], ",", "L"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"ColorFunction", "->", "\"\<Rainbow\>\""}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Curvature Kretschmann Map\>\""}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<z\>\""}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "K2D2", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"SECTION", " ", "53"}], "-", "TIPLER"}], "&"}], " ", "KROLAK", 
     " ", "TESTS"}], "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== SECTION 53: Singularities Tests ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Rexp", "[", "xVal_", "]"}], ":=", 
     RowBox[{"Kretschmann", "[", 
      RowBox[{"xVal", ",", "0"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Rvals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Rexp", "[", "xVal", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"xVal", ",", "grid"}], "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"KrolakIntegral", "=", 
     RowBox[{
      RowBox[{"Total", "[", "Rvals", "]"}], "*", "dx"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TiplerIntegral", "=", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"Rvals", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "j"}], "}"}]}], "]"}], "*", "dx"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", 
          RowBox[{"Length", "[", "grid", "]"}]}], "}"}]}], "]"}], "*", 
      "dx"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Krolak integral: \>\"", ",", "KrolakIntegral"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Tipler integral: \>\"", ",", "TiplerIntegral"}], "]"}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== ALL WARP BUBBLE VERIFICATIONS COMPLETE ===\>\"", 
     "]"}], ";"}]}]}]], "Input",
